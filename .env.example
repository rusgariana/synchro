# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Google OAuth Client ID (Required)
# Get yours at: https://console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# App URL (used for CORS origin validation in API routes)
# In development: http://localhost:3000
# In production: https://your-domain.com
NEXT_PUBLIC_APP_URL=

# Example: If you add Redis for persistent session storage
# REDIS_URL=your_redis_connection_string_here
